rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "performance@x.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings collection
    match /settings/{documentId} {
      allow read: if true;
      
      allow create: if isAdmin() || (
        documentId == "global" && 
        request.resource.data.keys().hasAll(['instagram', 'whatsapp', 'email', 'views']) &&
        request.resource.data.instagram is string &&
        request.resource.data.whatsapp is string &&
        request.resource.data.email is string &&
        request.resource.data.views is number
      );
      
      allow update: if isAdmin() || (
        // Public can only increment the views counter
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
        request.resource.data.views is number &&
        (resource.data.views == null || request.resource.data.views == resource.data.views + 1)
      );

      allow delete: if isAdmin();
    }

    // Leads / Contact messages collection
    match /leads/{leadId} {
      allow read: if isAdmin();
      
      allow create: if isValidId(leadId) &&
        request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.email is string && request.resource.data.email.size() <= 200 &&
        request.resource.data.message is string && request.resource.data.message.size() <= 5000;

      allow update, delete: if isAdmin();
    }

    // Blog posts collection
    match /posts/{postId} {
      allow read: if true;
      
      allow create, update: if isAdmin() && isValidId(postId) &&
        request.resource.data.keys().hasAll(['title', 'content', 'summary', 'imageUrl', 'category', 'author', 'createdAt']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 300 &&
        request.resource.data.content is string && request.resource.data.content.size() <= 20000 &&
        request.resource.data.summary is string && request.resource.data.summary.size() <= 1000 &&
        request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() <= 2000 &&
        request.resource.data.category is string && request.resource.data.category.size() <= 100 &&
        request.resource.data.author is string && request.resource.data.author.size() <= 100 &&
        request.resource.data.createdAt is string;

      allow delete: if isAdmin() && isValidId(postId);
    }

    // Solutions collection
    match /solutions/{solutionId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(solutionId) &&
        request.resource.data.keys().hasAll(['title', 'icon', 'shortDesc', 'longDesc', 'category', 'benefits']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 300 &&
        request.resource.data.icon is string && request.resource.data.icon.size() <= 100 &&
        request.resource.data.shortDesc is string && request.resource.data.shortDesc.size() <= 1000 &&
        request.resource.data.longDesc is string && request.resource.data.longDesc.size() <= 10000 &&
        request.resource.data.category is string &&
        request.resource.data.benefits is list;
      allow delete: if isAdmin() && isValidId(solutionId);
    }

    // Programs collection
    match /programs/{programId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(programId) &&
        request.resource.data.keys().hasAll(['title', 'description', 'target', 'period', 'color', 'tagline']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 300 &&
        request.resource.data.description is string && request.resource.data.description.size() <= 5000 &&
        request.resource.data.target is string && request.resource.data.target.size() <= 500 &&
        request.resource.data.period is string && request.resource.data.period.size() <= 200 &&
        request.resource.data.color is string && request.resource.data.color.size() <= 200 &&
        request.resource.data.tagline is string && request.resource.data.tagline.size() <= 500;
      allow delete: if isAdmin() && isValidId(programId);
    }

    // Testimonials collection
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(testimonialId) &&
        request.resource.data.keys().hasAll(['name', 'role', 'company', 'text', 'rating']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.role is string && request.resource.data.role.size() <= 200 &&
        request.resource.data.company is string && request.resource.data.company.size() <= 200 &&
        request.resource.data.text is string && request.resource.data.text.size() <= 2000 &&
        request.resource.data.rating is number;
      allow delete: if isAdmin() && isValidId(testimonialId);
    }

    // Gallery collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(galleryId) &&
        request.resource.data.keys().hasAll(['url', 'caption', 'category']) &&
        request.resource.data.url is string && request.resource.data.url.size() <= 2000 &&
        request.resource.data.caption is string && request.resource.data.caption.size() <= 1000 &&
        request.resource.data.category is string && request.resource.data.category.size() <= 200;
      allow delete: if isAdmin() && isValidId(galleryId);
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(reviewId) &&
        request.resource.data.keys().hasAll(['name', 'role', 'company', 'rating', 'text', 'date', 'avatarBg']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.role is string && request.resource.data.role.size() <= 200 &&
        request.resource.data.company is string && request.resource.data.company.size() <= 200 &&
        request.resource.data.text is string && request.resource.data.text.size() <= 2000 &&
        request.resource.data.rating is number &&
        request.resource.data.date is string && request.resource.data.date.size() <= 100 &&
        request.resource.data.avatarBg is string && request.resource.data.avatarBg.size() <= 100;
      allow delete: if isAdmin() && isValidId(reviewId);
    }
  }
}
