rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "performance@x.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings collection
    match /settings/{documentId} {
      allow read: if true;
      
      allow create: if isAdmin() || (
        documentId == "global" && 
        request.resource.data.keys().hasAll(['instagram', 'whatsapp', 'email', 'views']) &&
        request.resource.data.instagram is string &&
        request.resource.data.whatsapp is string &&
        request.resource.data.email is string &&
        request.resource.data.views is number
      );
      
      allow update: if isAdmin() || (
        // Public can only increment the views counter
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
        request.resource.data.views is number &&
        (resource.data.views == null || request.resource.data.views == resource.data.views + 1)
      );

      allow delete: if isAdmin();
    }

    // Leads / Contact messages collection
    match /leads/{leadId} {
      allow read: if isAdmin();
      
      allow create: if isValidId(leadId) &&
        request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
        request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
        request.resource.data.email is string && request.resource.data.email.size() <= 200 &&
        request.resource.data.message is string && request.resource.data.message.size() <= 5000;

      allow update, delete: if isAdmin();
    }

    // Blog posts collection
    match /posts/{postId} {
      allow read: if true;
      
      allow create, update: if isAdmin() && isValidId(postId) &&
        request.resource.data.keys().hasAll(['title', 'content', 'summary', 'imageUrl', 'category', 'author', 'createdAt']) &&
        request.resource.data.title is string && request.resource.data.title.size() <= 300 &&
        request.resource.data.content is string && request.resource.data.content.size() <= 20000 &&
        request.resource.data.summary is string && request.resource.data.summary.size() <= 1000 &&
        request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() <= 2000 &&
        request.resource.data.category is string && request.resource.data.category.size() <= 100 &&
        request.resource.data.author is string && request.resource.data.author.size() <= 100 &&
        request.resource.data.createdAt is string;

      allow delete: if isAdmin() && isValidId(postId);
    }
  }
}
